      "dashArray": "8 6"
    },
    {
      "kind": "satellite",
      "label": "卫星",
      "lineType": "dashed",
      "color": "#a855f7",
      "strokeWidth": 1.8,
      "dashArray": "2 4 10 4"
    },
    {
      "kind": "unreachable",
      "label": "不通",
      "lineType": "dashed",
      "color": "#f43f5e",
      "strokeWidth": 2.2,
      "dashArray": "6 4"
    }
  ]
